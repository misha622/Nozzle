# Nozzle Configuration
NOZZLE_ENV=development
NOZZLE_DEBUG=true
NOZZLE_SECRET_KEY=change-me-to-a-random-string

# Database
DATABASE_URL=postgresql+asyncpg://nozzle:nozzle@localhost:5432/nozzle
DATABASE_URL_SYNC=postgresql://nozzle:nozzle@localhost:5432/nozzle

# Redis
REDIS_URL=redis://localhost:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000

# Wazuh (example)
WAZUH_API_URL=https://wazuh.example.com
WAZUH_USER=admin
WAZUH_PASSWORD=changeme